# API endpoints
PUBLIC_REST_URL=http://localhost:1317
PUBLIC_RPC_URL=http://localhost:26657

# Web3Auth client ID for social login (Google)
# Get yours at https://dashboard.web3auth.io
PUBLIC_WEB3AUTH_CLIENT_ID=your_web3auth_client_id_here

# Web3Auth network configuration
# Valid values: sapphire_devnet, sapphire_mainnet, testnet (legacy), mainnet (legacy)
PUBLIC_WEB3AUTH_NETWORK=sapphire_devnet

# AI Assistant Configuration (Morpheus API)
# Morpheus API endpoint URL — used by server proxy (nginx/dev), not by browser
PUBLIC_MORPHEUS_URL=https://api.mor.org/api/v1

# Morpheus model to use for chat
PUBLIC_MORPHEUS_MODEL=minimax-m2.5

# Morpheus API key — server-side only, never sent to browser
# Injected by nginx (prod) or rsbuild dev proxy into upstream requests
MORPHEUS_API_KEY=

# PWR token factory denom (optional, defaults to local factory address)
# PUBLIC_PWR_DENOM=factory/manifest1.../upwr

# Chain configuration (optional)
# PUBLIC_CHAIN_ID=manifest-ledger-beta
# PUBLIC_GAS_PRICE=0.0025umfx

# Faucet endpoint URL (optional, enables auto-refill when set)
# PUBLIC_FAUCET_URL=http://localhost:8000

# AI tuning (optional, all values in milliseconds unless noted)
# PUBLIC_AI_STREAM_TIMEOUT_MS=30000          # Per-chunk stream timeout
# PUBLIC_AI_DEPLOY_PROVISION_TIMEOUT_MS=300000 # Deploy provisioning timeout
# PUBLIC_AI_TOOL_API_TIMEOUT_MS=15000        # Blockchain API call timeout
# PUBLIC_AI_MAX_RETRIES=3                    # Stream retry attempts (count)
# PUBLIC_AI_CONFIRMATION_TIMEOUT_MS=300000   # TX confirmation auto-cancel
# PUBLIC_AI_MAX_TOOL_ITERATIONS=10           # Tool calls per message (count)
# PUBLIC_AI_MAX_MESSAGES=200                 # Chat history depth (count)
